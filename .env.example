# Copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./league.db

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google/callback

# JWT — generate with: openssl genrsa -out jwt_private.pem 2048
# Then: openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY_PATH=./jwt_private.pem
JWT_PUBLIC_KEY_PATH=./jwt_public.pem

# Cookie signing secret — any long random string
COOKIE_SECRET=change-me-to-something-random-and-long
