{
  "name": "xc-league",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "cd frontend && vite build --outDir ../dist/client",
    "build": "npm run build:server && npm run build:client",
    "dev:server": "tsx watch src/server.ts",
    "dev:client": "cd frontend && vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "start": "node dist/migrate.js && node dist/server.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && cd frontend && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test && cd frontend && npm run test"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^8.1.1",
    "@fastify/static": "^7.0.4",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^17.3.1",
    "fastify": "^4.26.2",
    "geographiclib-geodesic": "^2.1.1",
    "igc-parser": "^2.0.0",
    "jose": "^5.2.4",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@flydotio/dockerfile": "^0.7.10",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.20",
    "@types/qrcode": "^1.5.6",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^8.2.2",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
